# Copy to .env.local (or the relevant .env.<mode>) and fill in values.
# Only variables prefixed with VITE_ are exposed to the client.

# App environment: development | staging | production
VITE_APP_ENV=development

# Base URL for API requests
VITE_API_BASE_URL=

# --- Resumable video upload (see docs/BACKEND_UPLOAD_SPEC.md) ---
# Bytes per multipart part. Must be >= 5 MiB (S3 rule). Default 6 MiB.
VITE_UPLOAD_PART_SIZE=6291456
# Max concurrent part uploads. Default 4.
VITE_UPLOAD_CONCURRENCY=4
# Max allowed video duration in seconds. Default 30.
VITE_UPLOAD_MAX_DURATION_SEC=30
