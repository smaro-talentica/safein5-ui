{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hook-protect-env.mjs",
            "timeout": 10,
            "statusMessage": "Checking env-file guardrail"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hook-format-and-lint.mjs",
            "timeout": 120,
            "statusMessage": "Linting + formatting edited file"
          },
          {
            "type": "command",
            "command": "node .claude/hook-stitch-guardrail.mjs",
            "timeout": 15,
            "statusMessage": "Checking stitch-export conventions"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hook-readme-sync.mjs",
            "timeout": 15,
            "statusMessage": "Checking docs are in sync with code"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "safein5@safein5-marketplace": true
  }
}
